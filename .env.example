# Environment variables for Tallee-o
# Copy this file to .env.local and adjust values as needed

# Next.js configuration
NEXT_PUBLIC_APP_NAME=Tallee-o
NEXT_PUBLIC_APP_DESCRIPTION="Split bills easily with friends"

# Note: For Release 1 (Guest Mode), no database or authentication is required
# All data is stored in localStorage only

# For future Release 2 (Account Mode):
# DATABASE_URL=postgresql://user:password@localhost:5432/tallee_o
# NEXTAUTH_SECRET=your-secret-key-here
# NEXTAUTH_URL=http://localhost:3000